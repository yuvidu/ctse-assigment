# API gateway (set in Vercel / Netlify project env before build — not committed)
VITE_API_BASE_URL=http://localhost:8087

# Stripe is handled in the browser: POST /payments is public (no VITE_PAYMENT_BASIC).
# Set on the payment-service: PAYMENT_GATEWAY_PROVIDER=stripe and STRIPE_API_KEY=sk_test_...

# Optional: demo card page at /payment (server must use PAYMENT_GATEWAY_PROVIDER=mock)
# VITE_USE_MOCK_PAYMENT_PAGE=true

# Admin panel is only at /admin/login (not shown in the navbar).
# Defaults match docker-compose BOOKING_ADMIN_USERNAME / BOOKING_ADMIN_PASSWORD:
#   username: admin
#   password: admin-pass
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=admin-pass
